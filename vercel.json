{
  "version": 2,
  "builds": [
    {
      "src": "analyzer/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/*",
      "use": "@vercel/static"
    },
    {
      "src": "js/*",
      "use": "@vercel/static"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/analyzer/index.html"
    },
    {
      "src": "/history",
      "dest": "/analyzer/history.html"
    },
    {
      "src": "/analysis",
      "dest": "/analyzer/detail.html"
    },
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    }
  ]
}